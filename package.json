{
    "name": "md-to-pdf-renderer",
    "version": "0.2.3",
    "type": "module",
    "license": "MIT",
    "description": "CLI to render Markdown files to print-ready PDF with optional HTML output, Mermaid, KaTeX, TOC, footnotes, and GitHub-style callouts",
    "homepage": "https://github.com/hahabsw/md-to-pdf-renderer#readme",
    "bugs": {
        "url": "https://github.com/hahabsw/md-to-pdf-renderer/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/hahabsw/md-to-pdf-renderer.git"
    },
    "keywords": [
        "markdown",
        "pdf",
        "renderer",
        "cli",
        "markdown-to-pdf",
        "documentation",
        "mermaid",
        "katex",
        "puppeteer"
    ],
    "bin": {
        "md-to-pdf-renderer": "./bin/md-to-pdf-renderer.mjs"
    },
    "exports": {
        ".": "./src/render-pdfs.mjs"
    },
    "files": [
        "bin",
        "src",
        "LICENSE",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "render": "node src/render-pdfs.mjs",
        "test": "node --test"
    },
    "dependencies": {
        "katex": "^0.16.42",
        "markdown-it": "^14.1.0",
        "markdown-it-footnote": "^4.0.0",
        "markdown-it-task-lists": "^2.1.1",
        "mermaid": "^11.13.0",
        "puppeteer": "^24.40.0"
    }
}
